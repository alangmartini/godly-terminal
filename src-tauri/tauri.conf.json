{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Godly Terminal",
  "version": "0.12.0",
  "identifier": "com.godly.terminal",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run unlock -- --release && cd src-tauri && cargo build -p godly-daemon -p godly-mcp -p godly-notify -p godly-pty-shim -p godly-remote -p godly-iced-shell --release && cd .. && pnpm run build:check",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Godly Terminal",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "dragDropEnabled": true,
        "zoomHotkeysEnabled": false,
        "additionalBrowserArgs": "--disable-features=msWebOOUI,msPdfOOUI,msSmartScreenProtection --remote-debugging-port=9222"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "nsis-hooks.nsh"
      }
    },
    "resources": {
      "target/release/godly-daemon.exe": "godly-daemon.exe",
      "target/release/godly-mcp.exe": "godly-mcp.exe",
      "target/release/godly-notify.exe": "godly-notify.exe",
      "target/release/godly-pty-shim.exe": "godly-pty-shim.exe",
      "target/release/godly-remote.exe": "godly-remote.exe",
      "target/release/godly-native.exe": "godly-native.exe",
      "sounds/*": "sounds/",
      "soundpacks/**/*": "soundpacks/"
    }
  },
  "plugins": {}
}
